# Python キャッシュを無視
__pycache__/
*.pyc
*.pyo
*.pyd

# 仮想環境を無視
venv/
.env/
.venv/
.env

# IDE・エディタ設定ファイルを無視
.vscode/
.idea/
*.sublime-workspace

# ログファイルや一時ファイルを無視
*.log
*.tmp
.DS_Store  # macOS の不要ファイル

# ユーザーから入力されるデータを無視（個人情報保護）
input_data_folder/*
!input_data_folder/.gitkeep

# 結果出力フォルダを無視（個人情報保護）
result_output_folder/*
!result_output_folder/.gitkeep

# 実行時に生成される中間・出力ファイルを無視
merged_output.csv